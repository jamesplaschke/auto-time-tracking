# Per-user Rocketlane API keys (each user needs their own)
ROCKETLANE_API_KEY_JAMES=your-key-here
ROCKETLANE_API_KEY_KEVIN=your-key-here

# Legacy fallback (used if no per-user key is found)
# ROCKETLANE_API_KEY=your-key-here

# Slack notifications (shared — one bot for all users)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Phase 2: Slack listener (Socket Mode daemon)
SLACK_APP_TOKEN=xapp-your-app-level-token  # Settings > Socket Mode > App-Level Tokens
ANTHROPIC_API_KEY=sk-ant-your-key-here    # For thread-reply correction interpretation
